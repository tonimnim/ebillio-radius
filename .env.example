# ---------------------------------------------------------------------------
# eBillio FreeRADIUS - environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env` and replace every CHANGE_ME_* value with a real
# secret BEFORE running `docker compose up`.
#
#   cp .env.example .env
#   # then edit .env and fill in strong, unique values
#
# Security model:
#   * `.env` is gitignored and MUST NEVER be committed.
#   * `.env.example` (this file) is tracked and MUST contain only placeholders.
#   * Secrets should be generated with a CSPRNG, e.g.:
#       openssl rand -base64 32 | tr -d '/+=' | head -c 40
#   * Minimum length: 32 chars. Prefer 40+ for RADIUS shared secrets.
#   * Rotate on any suspected exposure, on staff offboarding, and on a regular
#     cadence (see docs/SECRETS.md).
#
# Full rotation procedure and incident response: docs/SECRETS.md
# ---------------------------------------------------------------------------

# Shared secret between FreeRADIUS and NAS/BRAS clients (auth/acct).
# Must match the `secret` configured on every NAS in clients.conf.
RADIUS_SECRET=CHANGE_ME_use_openssl_rand_base64_32

# MySQL root password. Only used at container init and for admin tasks.
# Application code must NEVER use root.
DB_ROOT_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32

# Application DB user that FreeRADIUS connects as. Name can stay `radius`.
DB_USERNAME=radius

# Password for the application DB user above.
DB_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32

# Status-Server / monitoring shared secret. Used by the FreeRADIUS Status
# virtual server (sites-enabled/status) and scraped by the Prometheus
# exporter (freeradius_exporter container). Should be unique; not shared
# with NAS auth.
STATUS_SECRET=CHANGE_ME_use_openssl_rand_base64_32

# CoA / Disconnect-Message shared secret (RFC 5176). MUST differ from
# RADIUS_SECRET — the entrypoint refuses to start if they match. Used by
# the billing app when it sends radclient/pyrad CoA-Request and
# Disconnect-Request packets to NAS devices, and by FreeRADIUS to accept
# inbound CoA from the billing app.
COA_SECRET=CHANGE_ME_use_openssl_rand_base64_32

# MySQL exporter password (Prometheus monitoring). Used by mysqld_exporter
# to connect as the dedicated `exporter` MySQL user. See monitoring/README.md
# for the SQL snippet that creates this user with read-only privileges.
MYSQLD_EXPORTER_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32
