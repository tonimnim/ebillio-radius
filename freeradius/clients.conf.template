#######################################################################
#  eBillio RADIUS - clients.conf
#
#  FreeRADIUS 3.2.7 NAS client definitions for the eBillio AAA stack.
#  Serves ISP subscribers across Africa (and roaming users from US,
#  China, etc). Treat this file as critical security configuration.
#
#  -------------------------------------------------------------------
#  TEMPLATING
#  -------------------------------------------------------------------
#  This file is a template processed by `envsubst` at container start
#  time (see docker-entrypoint.sh). Any ${VAR} placeholder is expanded
#  from the environment. Currently only ${RADIUS_SECRET} is supported
#  by the entrypoint; adding new variables requires updating
#  docker-entrypoint.sh as well.
#
#  ${RADIUS_SECRET} is the ONLY secret injected from the environment
#  and should be considered a bootstrap / lab secret. Production NAS
#  devices MUST each have their own unique, long, random secret -
#  never reuse ${RADIUS_SECRET} across real NAS devices.
#
#  -------------------------------------------------------------------
#  SECURITY MODEL
#  -------------------------------------------------------------------
#  1. Per-NAS unique secrets. Every physical NAS (Mikrotik, Cisco,
#     Huawei, etc.) gets its own `secret`. If one device is
#     compromised, the blast radius is limited to that device.
#
#  2. Never use 0.0.0.0/0. Only list exact NAS IPs or the tightest
#     possible subnet for a managed POP. A permissive client block is
#     equivalent to leaving RADIUS open to the internet.
#
#  3. Never reuse secrets. Do not copy/paste the same `secret` across
#     client blocks. Generate fresh ones, e.g.:
#         openssl rand -base64 32
#
#  4. Blast-RADIUS mitigation (CVE-2024-3596). Every client block
#     MUST set `require_message_authenticator = yes`. This forces
#     clients to include the Message-Authenticator attribute on all
#     Access-Request packets and closes the Blast-RADIUS MD5 collision
#     attack. Mikrotik RouterOS 7.15+ and most modern NAS firmware
#     support this - upgrade any device that does not.
#
#  5. Connection limits. `limit { ... }` caps the number of concurrent
#     sockets and idle time per client, protecting the server from a
#     misbehaving or compromised NAS.
#
#  6. Explicit `proto = udp`. Stated explicitly now so that future
#     RadSec (RADIUS-over-TLS) migration is a clean diff: those
#     clients will be `proto = tcp` inside a TLS listener.
#
#  -------------------------------------------------------------------
#  HOW TO ADD A PRODUCTION NAS
#  -------------------------------------------------------------------
#  You MUST add your real production NAS devices before going live.
#  Two options:
#
#    (a) Static: copy one of the commented Mikrotik examples below,
#        give it a unique shortname, ipaddr and secret, and uncomment.
#
#    (b) Dynamic: enable SQL-backed NAS loading by setting
#        `read_clients = yes` in mods-enabled/sql and populating the
#        `nas` table in MySQL. See the note at the bottom of this
#        file. This is the recommended approach once you have more
#        than a handful of NAS devices.
#
#  References:
#    - CVE-2024-3596 / Blast-RADIUS: https://www.blastradius.fail/
#    - FreeRADIUS clients.conf docs: man clients.conf
#######################################################################


#######################################################################
#  localhost - local radclient / health-check testing
#
#  Used by radclient from inside the container for smoke tests and
#  by any sidecar health-check tooling. Do NOT point external devices
#  at this block.
#######################################################################
client localhost {
    ipaddr                        = 127.0.0.1
    proto                         = udp
    secret                        = ${RADIUS_SECRET}
    shortname                     = localhost
    nastype                       = other
    require_message_authenticator = yes

    limit {
        max_connections = 16
        idle_timeout    = 30
    }
}


#######################################################################
#  dockernet - other containers on the same Docker bridge network
#
#  This block permits sibling containers (e.g. an admin panel, a
#  monitoring/exporter container, or a test harness) to speak RADIUS
#  to FreeRADIUS over the internal Docker bridge.
#
#  The compose network is pinned to 172.28.0.0/16 in docker-compose.yml
#  (see the `networks.default.ipam.config.subnet` block). If you change
#  that, update this CIDR to match. Verify with:
#
#      docker network inspect ebillio-radius_default \
#          --format '{{range .IPAM.Config}}{{.Subnet}}{{end}}'
#
#  Do NOT widen this back to 172.16.0.0/12 - that covers the entire
#  Docker default range and any rogue container on the host would be
#  accepted as a NAS.
#######################################################################
client dockernet {
    ipaddr                        = 172.28.0.0/16
    proto                         = udp
    secret                        = ${RADIUS_SECRET}
    shortname                     = dockernet
    nastype                       = other
    require_message_authenticator = yes

    limit {
        max_connections = 16
        idle_timeout    = 30
    }
}


#######################################################################
#  DYNAMIC CLIENTS POOL (for ebillio tenant routers)
#  -------------------------------------------------------------------
#  Accepts RADIUS packets from any IPv4 source. For each new source
#  IP, FreeRADIUS runs a SQL lookup against the `nas` table (see the
#  `dynamic_clients` virtual server in sites-enabled/dynamic-clients).
#  If a row exists where `nasname` = source IP, the row's `secret` is
#  loaded, the packet signature is validated, and the client is cached
#  for `lifetime` seconds. No row → silent drop.
#
#  Why this is safe with ipaddr = 0.0.0.0/0:
#    * FreeRADIUS rate-limits new dynamic client creation to 1/sec
#      (hardcoded, DoS protection).
#    * Shared secret per-NAS is a strong random 40+ char string —
#      brute-force infeasible.
#    * require_message_authenticator = yes forces MA on every packet
#      (Blast-RADIUS / CVE-2024-3596 mitigation).
#    * A packet from an IP with no matching `nas` row is discarded
#      silently — no amplification, no leak.
#
#  Interaction with backend heartbeat:
#    * Router bootstraps → backend writes nas.nasname = public IP.
#    * Router's IP changes → backend heartbeat UPDATEs nas.nasname.
#    * Cache expires after `lifetime` → next packet re-runs SQL lookup
#      at the new IP. Self-healing, no FreeRADIUS reload needed.
#
#  Worst-case auth outage during IP rotation:
#    lifetime + (heartbeat interval) = ~6 minutes (tunable).
#######################################################################
client ebillio_dynamic_pool {
    ipaddr           = 0.0.0.0/0
    netmask          = 0
    dynamic_clients  = dynamic_clients
    lifetime         = 300
}


