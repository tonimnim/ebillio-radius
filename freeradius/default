server default {
    # Standard RADIUS ports
    listen {
        type = auth
        ipaddr = *
        port = 1812
    }

    listen {
        type = acct
        ipaddr = *
        port = 1813
    }

    # Alternate ports for networks that block 1812/1813
    listen {
        type = auth
        ipaddr = *
        port = 8812
    }

    listen {
        type = acct
        ipaddr = *
        port = 8813
    }

    authorize {
        preprocess
        # chap / mschap here detect CHAP-Password / MS-CHAP-Challenge in the
        # Access-Request and set Auth-Type accordingly, so the authenticate
        # section below routes to the right handler. WITHOUT these, CHAP
        # and MS-CHAP packets get rejected even when the password is
        # correct in radcheck. PAP works without this because radclient
        # and NASes typically send User-Password in the clear.
        chap
        mschap
        # `sql` pulls radcheck/radreply for the user. Each subscriber must
        # have `Simultaneous-Use := 1` in radcheck for the session{} block
        # below to enforce single-device login. Without that attribute
        # FreeRADIUS will not call session{} at all.
        sql
        pap
    }

    authenticate {
        Auth-Type PAP {
            pap
        }
        Auth-Type CHAP {
            chap
        }
        Auth-Type MS-CHAP {
            mschap
        }
    }

    preacct {
        preprocess
        # acct_unique computes Acct-Unique-Session-Id — a hash of
        # Acct-Session-Id + NAS-IP-Address + Client-IP-Address. The SQL
        # accounting queries key Interim-Update and Stop UPDATEs on this
        # value. WITHOUT this line, acctuniqueid is empty, the UPDATE
        # never matches, and billing silently loses interim counters and
        # stop terminate-cause. This is the canonical upstream wiring.
        acct_unique
    }

    accounting {
        sql
    }

    # Simultaneous-Use enforcement.
    # When a user has `Simultaneous-Use := N` in radcheck, FreeRADIUS runs
    # this section during Access-Request to count currently-open sessions
    # (rows in radacct where acctstoptime IS NULL) for that username. If
    # the count is >= N the Access-Request is rejected. `sql` here points
    # at the simul_count_query defined in mods-available/sql. Stale rows
    # in radacct will therefore cause false rejections — they are closed
    # by scripts/cleanup-stale-sessions.sh running from cron every 5 min.
    session {
        sql
    }

    post-auth {
        sql
    }
}
